# API Keys for eit-market-data
# Copy this file to .env and fill in your keys

# US Market Data
# FRED: Free API key from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_free_key_here

# SEC EDGAR: Format "YourName your@email.com" (no registration needed)
SEC_EDGAR_USER_AGENT=Your Name your@email.com

# Korean Market Data
# DART: https://opendart.fss.or.kr/uss/umt/EgovMberInsertView.do
DART_API_KEY=your_dart_key

# ECOS: https://ecos.bok.or.kr
ECOS_API_KEY=your_ecos_key
